{
  "name": "material-resources-management-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "test": "bun test",
    "typecheck": "bun ./node_modules/typescript/lib/tsc.js -p tsconfig.json --noEmit",
    "db:generate": "bun ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "bun ./node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@frms/shared": "workspace:*",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "nanoid": "^5.1.9",
    "postgres": "^3.4.9",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
