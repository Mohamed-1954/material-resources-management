# --- Shared ---
NODE_ENV=development

# --- Database ---
# Local dev defaults to host port 15432 (mapped from postgres:5432 in infra/docker-compose.yml)
DATABASE_URL=postgres://faculty:faculty@localhost:15432/faculty_resources

# --- API ---
API_PORT=3001
API_BASE_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:5173

# --- Better Auth ---
# REQUIRED. Generate with: openssl rand -base64 32   (>=32 chars)
BETTER_AUTH_SECRET=replace-me-with-a-32-char-min-random-secret
BETTER_AUTH_URL=http://localhost:3001
# Comma-separated list of origins allowed to call the API
TRUSTED_ORIGINS=http://localhost:5173

# --- OAuth: GitHub (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- OAuth: Google (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Web (Vite) ---
VITE_API_BASE_URL=http://localhost:3001
